# Server
PORT=8019

# CORS — comma-separated origins (use * for dev, restrict in production)
CORS_ORIGINS=*

# Access control — set a strong password to require users to authenticate.
# Users enter this in Settings → Access Token in the UI.
# Leave blank to disable auth (open access).
# ACCESS_PASSWORD=your-strong-password-here

# AI provider used by engine.py (optional server-side fallback)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# OPENAI_API_KEY=sk-proj-your-key-here
