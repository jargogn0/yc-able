{
  "name": "19labs",
  "version": "1.0.0",
  "description": "19Labs - The Cursor for Data Science",
  "main": "main.js",
  "author": "19Labs",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac --x64",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.19labs.app",
    "productName": "19Labs",
    "copyright": "Copyright © 2025 19Labs",
    "files": ["main.js", "preload.js", "splash.html"],
    "mac": {
      "target": [
        {"target": "dmg", "arch": ["x64", "arm64"]},
        {"target": "zip", "arch": ["x64", "arm64"]}
      ],
      "category": "public.app-category.developer-tools",
      "icon": "icon.png",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    },
    "nsis": {
      "oneClick": true
    },
    "dmg": {
      "title": "19Labs ${version}",
      "background": null,
      "contents": [
        {"x": 130, "y": 220},
        {"x": 410, "y": 220, "type": "link", "path": "/Applications"}
      ],
      "window": {"width": 540, "height": 380}
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
